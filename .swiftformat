# file options
#  --exclude Tests/XCTestManifests.swift,Tests/BadConfig,Snapshots,Build,PluginTests

# format options
--swiftversion 5.0
--allman false
--binarygrouping 4,8
--commas always
--decimalgrouping 3,6
--elseposition same-line
--voidtype void
--exponentcase lowercase
--exponentgrouping disabled
--fractiongrouping disabled
--header ignore
--hexgrouping 4,8
--hexliteralcase uppercase
--ifdef indent
--indent 4
--indentcase false
--importgrouping testable-bottom
--linebreaks lf
--maxwidth none
--octalgrouping 4,8
--operatorfunc spaced
--patternlet hoist
--ranges spaced
# --self remove
--semicolons inline
# --stripunusedargs always
--trimwhitespace always
--wraparguments preserve
--wrapcollections preserve
--wrapconditions after-first

# rules

# Keep explicit self when compiler requires closure capture semantics.
--disable redundantSelf
# --enable unusedPrivateDeclarations
--enable emptyExtensions
--enable docComments
# --enable noForceTryInTests
# --enable noForceUnwrapInTests
# --enable noGuardInTests
# --enable preferFinalClasses
# --enable redundantAsync
--enable redundantEquatable
# --enable redundantMemberwiseInit
# --enable redundantProperty
# --enable redundantThrows
